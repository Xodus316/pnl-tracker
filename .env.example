POSTGRES_DB=pnl
POSTGRES_USER=pnl
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5434

API_PORT=4001
WEB_PORT=8080

TZ=America/New_York

# Postgres backups (cron-style; @daily = 03:00 daily by default)
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# Google Sheets sync (optional). Place service-account JSON at ./credentials/google.json
# and set the spreadsheet ID below. Leave blank to disable.
GOOGLE_SHEET_ID=
# Default range covers the 16-column trade layout. Override if your sheet name differs:
#   GOOGLE_SHEET_RANGE=Trades!A:P
GOOGLE_SHEET_RANGE=A:P
